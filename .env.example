# Encryption
ENCRYPTION_KEY=your-256-bit-encryption-key-here

# JWT
JWT_SECRET=your-jwt-secret-here

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/creeklend

# Google Analytics
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta/Facebook
NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id
META_CAPI_ACCESS_TOKEN=your-meta-capi-token

# Jornaya/TrustedForm
NEXT_PUBLIC_JORNAYA_CAMPAIGN_KEY=your-jornaya-key
NEXT_PUBLIC_TRUSTEDFORM_CERT_URL=

# Geo IP Service
GEO_IP_API_KEY=your-geo-ip-api-key

# Routing Number API
ROUTING_API_URL=https://www.routingnumbers.info/api/data.json

# Admin Setup (used for first admin user creation, remove after setup)
ADMIN_SETUP_KEY=your-one-time-setup-key
